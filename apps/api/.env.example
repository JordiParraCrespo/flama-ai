# App
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:3000

# JWT
JWT_SECRET=change-me-in-production
JWT_REFRESH_SECRET=change-me-refresh-in-production

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=flama
DB_PASSWORD=flama
DB_DATABASE=flama

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Email Provider: console | nodemailer | resend
EMAIL_PROVIDER=console
EMAIL_FROM=noreply@flama.dev

# SMTP (nodemailer)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Resend
RESEND_API_KEY=

# Storage Provider: local | s3
STORAGE_PROVIDER=local
UPLOAD_DIR=./uploads

# S3 (also works with Hetzner Object Storage, MinIO, etc.)
S3_ENDPOINT=
S3_REGION=auto
S3_BUCKET=flama
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# OAuth - Google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3001/api/auth/google/callback

# OAuth - GitHub
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:3001/api/auth/github/callback

# Sentry
SENTRY_DSN=
