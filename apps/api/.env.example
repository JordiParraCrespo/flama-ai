# App
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:3000

# Better Auth
# Generate a strong secret: `openssl rand -base64 32`
BETTER_AUTH_SECRET=change-me-in-production
# Public base URL of the API (used to build OAuth callback URLs)
BETTER_AUTH_URL=http://localhost:3001
# Mobile deep-link scheme (must match apps/mobile/app.config.ts -> scheme)
MOBILE_SCHEME=flama

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=flama
DB_PASSWORD=flama
DB_DATABASE=flama

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Email Provider: console | nodemailer | resend
EMAIL_PROVIDER=console
EMAIL_FROM=noreply@flama.dev

# SMTP (nodemailer)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Resend
RESEND_API_KEY=

# Storage Provider: local | s3
STORAGE_PROVIDER=local
UPLOAD_DIR=./uploads

# S3 (also works with Hetzner Object Storage, MinIO, etc.)
S3_ENDPOINT=
S3_REGION=auto
S3_BUCKET=flama
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# OAuth - Google
# Authorized redirect URI: ${BETTER_AUTH_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# OAuth - GitHub
# Authorization callback URL: ${BETTER_AUTH_URL}/api/auth/callback/github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Sentry
SENTRY_DSN=
